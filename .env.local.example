# === Doubao / LLM ===
DOUBAO_API_BASE_URL=http://ai-service.tal.com/openai-compatible
TAL_MLOPS_APP_ID=
TAL_MLOPS_APP_KEY=
DOUBAO_MODEL=gemini-3-flash
DOUBAO_MAX_ATTEMPTS=3
DOUBAO_RETRY_BASE_DELAY_MS=300

# === ASR (语音识别) ===
VOLCENGINE_ASR_API_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/recognize/flash
VOLCENGINE_APP_ID=
VOLCENGINE_ACCESS_TOKEN=
VOLCENGINE_RESOURCE_ID=volc.bigasr.auc_turbo

# === TTS (语音合成) ===
TTS_API_URL=https://openspeech.bytedance.com/api/v1/tts
TTS_APP_ID=
TTS_TOKEN=
TTS_CLUSTER=volcano_tts
TTS_UID=tino_user
TTS_VOICE_TYPE=en_male_tim_uranus_bigtts
TTS_ENCODING=mp3
TTS_SPEED_RATIO=1
TTS_RATE=24000
